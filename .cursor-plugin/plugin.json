{
  "name": "observe",
  "displayName": "Observe by Snowflake",
  "version": "0.1.0",
  "description": "Agent skills and MCP configuration for deploying and managing Observe's observability infrastructure",
  "author": {
    "name": "Observe by Snowflake"
  },
  "homepage": "https://github.com/observeinc/skills",
  "repository": "https://github.com/observeinc/skills",
  "logo": "assets/logo.svg",
  "keywords": [
    "observability",
    "kubernetes",
    "aws",
    "opentelemetry",
    "observe"
  ],
  "skills": "./skills/",
  "variables": {
    "type": "object",
